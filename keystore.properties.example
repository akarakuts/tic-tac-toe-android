# Copy this file to "keystore.properties" in the repository root (keystore.properties is gitignored).
# storeFile path is relative to the repository root.
#
# Generate a keystore once (keep backups; losing the key means you cannot ship updates):
#   keytool -genkeypair -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# RuStore / store consoles: upload the certificate or AAB as described in their developer docs, e.g.:
#   https://www.rustore.ru/help/developers/publishing-and-verifying-apps/app-publication/new-version-app/upload-aab
#
storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
